<!DOCTYPE html>
<html>
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=0.75">
		<link rel="icon" type="image/x-icon" href="{{ url_for('static', filename='favicon.ico') }}">
		<title>{{ basename(path) or 'The Cross Central' }}</title>
		<link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}"/>
	</head>

	<body>
		<header>Index of <span class="path">/{{ path }}</span></header>
		<ul>
			{% if path and not basename(path).startswith(".") %}
				<li><a class="parent" href="{{ url_for('browse', rel_path=dirname(path)) }}">⬅ Parent</a></li>
			{% endif %}
			{% if not error %}
				{% for entry in entries %}
					{% if not entry.filename.startswith(".") %}
						<li>
							<a class="{{ 'folder' if entry.mimetype == 'inode-directory' else 'file' }}" href="{{ url_for('browse', rel_path=entry.filepath) }}">
								<span class="icon" style="background-image: url('static/icons/{{ entry.mimetype }}.svg');"></span> {{ entry.filename }}
							</a>
						</li>
					{% endif %}
				{% endfor %}
			{% else %}
				<li><em>{{ error }}</em></li>
			{% endif %}
		</ul>
	</body>
</html>
